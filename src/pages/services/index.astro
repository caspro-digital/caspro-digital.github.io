---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/blocks/Hero.astro';
import Section from '../../components/layout/Section.astro';
import SplitLayout from '../../components/layout/SplitLayout.astro';
import SectionIntro from '../../components/ui/SectionIntro.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';
import CTABanner from '../../components/blocks/CTABanner.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import SchemaOrg from '../../components/seo/SchemaOrg.astro';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services' },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://casprodigital.com/' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://casprodigital.com/services/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Website Builds',
    description: 'Custom websites designed to rank on Google and convert visitors into customers. Mobile-first, SEO-first, fully managed.',
    provider: { '@type': 'Organization', name: 'Caspro Digital', url: 'https://casprodigital.com' },
    url: 'https://casprodigital.com/services/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Website Growth & Management',
    description: 'Ongoing SEO, hosting, security, and monthly optimization for existing websites.',
    provider: { '@type': 'Organization', name: 'Caspro Digital', url: 'https://casprodigital.com' },
    url: 'https://casprodigital.com/services/#growth',
  },
];

const buildFeatures = [
  'Custom design tailored to your brand and industry',
  'Mobile-first responsive on every device',
  'SEO foundation: schema markup, meta tags, fast load times',
  'Contact forms and lead capture',
  'Google Analytics and Search Console setup',
  'Managed hosting, SSL, and daily backups',
  'Ongoing security monitoring',
  'Monthly content updates included',
];

const growthFeatures = [
  'Full site audit and migration to managed hosting',
  'SSL, security monitoring, and daily backups',
  'Uptime and performance monitoring',
  'Monthly SEO improvements and keyword tracking',
  'Content updates (hours per month based on plan)',
  'Monthly analytics and performance reports',
  'Google Business Profile optimization',
  'Priority support',
];
---

<BaseLayout
  title="Web Design & Website Management for Small Businesses | Caspro Digital"
  description="Custom website builds and ongoing website management for small businesses. SEO-first design, transparent pricing, fully managed hosting and security. See how we help."
>
  <SchemaOrg schema={schemas} />
  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero (primary bg) -->
  <Hero
    variant="page"
    title="How We Help"
    subtitle="Whether you need a brand new website or want to improve the one you have, we handle the design, SEO, hosting, security, and ongoing optimization \u2014 so you don\u2019t have to."
    primaryCta="See Pricing"
    primaryHref="/pricing/"
    secondaryCta="Schedule a Call"
    secondaryHref="/contact/"
  />

  <!-- Website Builds (light bg) -->
  <Section background="light">
    <SplitLayout split="50-50" alignY="top">
      <div>
        <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-2">Website Builds</h2>
        <p class="text-sm font-medium text-primary-light mb-4">For businesses that need a new website or a complete redesign.</p>
        <p class="text-base md:text-lg leading-relaxed text-neutral-600 mb-6">
          Every website we build is custom-designed, mobile-first, and engineered to rank on Google from day one. We don't use templates. We don't cut corners on SEO. And we don't disappear after launch \u2014 every build includes managed hosting, security, and ongoing support.
        </p>
        <Button href="/pricing/" variant="ghost" size="sm">
          See Pricing
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7l7 7-7 7" />
          </svg>
        </Button>
      </div>
      <div class="space-y-3">
        {buildFeatures.map((feature) => (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-success shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-base text-neutral-700">{feature}</span>
          </div>
        ))}
      </div>
    </SplitLayout>
  </Section>

  <!-- Website Growth & Management (white bg) -->
  <Section background="white" id="growth">
    <SplitLayout split="50-50" alignY="top" reverse>
      <div class="space-y-3">
        {growthFeatures.map((feature) => (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-success shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-base text-neutral-700">{feature}</span>
          </div>
        ))}
      </div>
      <div>
        <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-2">Website Growth & Management</h2>
        <p class="text-sm font-medium text-primary-light mb-4">For businesses that already have a website and want it to actually perform.</p>
        <p class="text-base md:text-lg leading-relaxed text-neutral-600 mb-6">
          Your website shouldn't just sit there. We take over your hosting, security, and updates, then actively improve your SEO, speed, and conversion rates every month. You get a dedicated team watching your site daily \u2014 and a monthly report showing exactly what we did and how it's working.
        </p>
        <Button href="/pricing/" variant="ghost" size="sm">
          See Pricing
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7l7 7-7 7" />
          </svg>
        </Button>
      </div>
    </SplitLayout>
  </Section>

  <!-- Free Audit CTA (light bg) -->
  <Section background="light">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">
        Not Sure What You Need?
      </h2>
      <p class="text-base md:text-lg leading-relaxed text-neutral-600 mb-8">
        Book a free 30-minute discovery call. We'll review your current website (or lack of one), identify the biggest opportunities, and recommend a clear path forward. No pressure, no obligation.
      </p>
      <Button href="/contact/" size="lg">Schedule a Free Consultation</Button>
    </div>
  </Section>

  <!-- CTA Banner (primary bg) -->
  <CTABanner />
</BaseLayout>

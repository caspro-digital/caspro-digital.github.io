---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/blocks/Hero.astro';
import Section from '../../components/layout/Section.astro';
import SectionIntro from '../../components/ui/SectionIntro.astro';
import Card from '../../components/ui/Card.astro';
import Icon from '../../components/ui/Icon.astro';
import Grid from '../../components/layout/Grid.astro';
import CTABanner from '../../components/blocks/CTABanner.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import SchemaOrg from '../../components/seo/SchemaOrg.astro';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/' },
  { label: 'Tech Consulting' },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://casprodigital.com/' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://casprodigital.com/services/' },
      { '@type': 'ListItem', position: 3, name: 'Tech Consulting', item: 'https://casprodigital.com/services/tech-consulting/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Tech Consulting for Small Businesses',
    description: 'Strategic technology guidance for small businesses. Tech stack audits, digital strategy, and ongoing advisory services.',
    provider: {
      '@type': 'Organization',
      name: 'Caspro Digital',
      url: 'https://casprodigital.com',
    },
    areaServed: { '@type': 'Country', name: 'United States' },
    url: 'https://casprodigital.com/services/tech-consulting/',
  },
];

const consultingServices = [
  {
    icon: 'search',
    title: 'Tech Stack Audit',
    price: '$750',
    description: 'A comprehensive review of every tool and platform your business uses. We identify redundancies, security risks, integration gaps, and cost-saving opportunities. You get a detailed report with prioritized recommendations and a clear action plan.',
  },
  {
    icon: 'lightbulb',
    title: 'Digital Strategy Session',
    price: '$250',
    description: 'A focused 90-minute session to tackle a specific technology challenge or decision. Whether you\u2019re evaluating new software, planning a digital initiative, or need an objective second opinion, you\u2019ll walk away with clear, actionable guidance.',
  },
  {
    icon: 'users',
    title: 'Ongoing Advisory',
    price: '$500 \u2013 $1,500/mo',
    description: 'Your fractional technology advisor on retainer. We attend vendor meetings, evaluate proposals, guide technology decisions, and provide ongoing strategic guidance so you always have an expert in your corner.',
  },
];

const forYouItems = [
  'You\u2019re paying for 6 different software tools and aren\u2019t sure you need all of them',
  'You want to automate parts of your business but don\u2019t know where to start',
  'You\u2019re about to invest in new technology and want an objective opinion first',
  'You need someone who can talk to your vendors and contractors on your behalf',
  'You want a technology roadmap for the next 12 months but don\u2019t have a CTO',
];
---

<BaseLayout
  title="Tech Consulting for Small Businesses | Caspro Digital"
  description="Strategic technology guidance for small businesses. Tech stack audits, digital strategy, and ongoing advisory services to help you make smarter digital decisions."
>
  <SchemaOrg schema={schemas} />
  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero (primary bg) -->
  <Hero
    variant="page"
    title="Technology Guidance Without the Enterprise Price Tag"
    subtitle="Most small businesses are paying for tools they don\u2019t need, missing tools that could save them hours, and making technology decisions based on whoever sold them last. Caspro Digital gives you a fractional technology advisor who actually understands small business."
    primaryCta="Book a Strategy Session"
    primaryHref="/contact/"
  />

  <!-- Services Breakdown (light bg) -->
  <Section background="light">
    <SectionIntro heading="Consulting Services" />
    <div class="space-y-8 max-w-4xl mx-auto">
      {consultingServices.map((service) => (
        <Card hover={false} class="border-l-4 border-l-primary-light">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
                <Icon name={service.icon} size={20} class="text-primary-light" />
              </div>
              <h3 class="text-lg md:text-xl font-semibold text-neutral-900">{service.title}</h3>
            </div>
            <span class="text-sm font-medium text-primary-light whitespace-nowrap">{service.price}</span>
          </div>
          <p class="text-base text-neutral-600 leading-relaxed">{service.description}</p>
        </Card>
      ))}
    </div>
  </Section>

  <!-- Who This Is For (white bg) -->
  <Section background="white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-6 text-center">
        This Is For You If...
      </h2>
      <Card hover={false}>
        <ul class="space-y-4">
          {forYouItems.map((item) => (
            <li class="flex items-start gap-3 text-base text-neutral-700">
              <svg class="w-5 h-5 text-primary-light shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </Card>
    </div>
  </Section>

  <!-- CTA Banner (primary bg) -->
  <CTABanner
    heading="Ready for a Smarter Technology Strategy?"
    description="Book a strategy session and get objective, actionable guidance tailored to your business."
    primaryCta="Book a Strategy Session"
    secondaryCta=""
  />
</BaseLayout>

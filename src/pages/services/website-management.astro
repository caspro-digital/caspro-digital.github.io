---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/blocks/Hero.astro';
import Section from '../../components/layout/Section.astro';
import SectionIntro from '../../components/ui/SectionIntro.astro';
import Card from '../../components/ui/Card.astro';
import Icon from '../../components/ui/Icon.astro';
import Grid from '../../components/layout/Grid.astro';
import PricingTable from '../../components/blocks/PricingTable.astro';
import CTABanner from '../../components/blocks/CTABanner.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import SchemaOrg from '../../components/seo/SchemaOrg.astro';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/' },
  { label: 'Website Management' },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://casprodigital.com/' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://casprodigital.com/services/' },
      { '@type': 'ListItem', position: 3, name: 'Website Management', item: 'https://casprodigital.com/services/website-management/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Website Management & Maintenance',
    description: 'Hassle-free website management for small businesses. Hosting, security, backups, updates, and performance monitoring.',
    provider: {
      '@type': 'Organization',
      name: 'Caspro Digital',
      url: 'https://casprodigital.com',
    },
    areaServed: { '@type': 'Country', name: 'United States' },
    url: 'https://casprodigital.com/services/website-management/',
    offers: {
      '@type': 'AggregateOffer',
      lowPrice: '150',
      highPrice: '500',
      priceCurrency: 'USD',
    },
  },
];

const pricingColumns = [
  {
    name: 'Essential',
    price: '$150/mo',
    description: 'Businesses that need reliable hosting and basic care.',
    features: [
      { text: 'Managed hosting', included: true },
      { text: 'SSL certificate', included: true },
      { text: 'Daily backups', included: true },
      { text: 'Security monitoring', included: true },
      { text: 'Uptime monitoring', included: true },
      { text: '1 hr/mo content updates', included: true },
      { text: 'Monthly analytics report', included: false },
      { text: 'SEO monitoring', included: false },
      { text: 'Priority support', included: false },
      { text: 'A/B testing', included: false },
      { text: 'Quarterly strategy call', included: false },
    ],
  },
  {
    name: 'Growth',
    price: '$300/mo',
    description: 'Growing businesses that want proactive optimization.',
    featured: true,
    features: [
      { text: 'Managed hosting', included: true },
      { text: 'SSL certificate', included: true },
      { text: 'Daily backups', included: true },
      { text: 'Security monitoring', included: true },
      { text: 'Uptime monitoring', included: true },
      { text: '3 hrs/mo content updates', included: true },
      { text: 'Monthly analytics report', included: true },
      { text: 'Basic SEO monitoring', included: true },
      { text: 'Priority support', included: true },
      { text: 'A/B testing', included: false },
      { text: 'Quarterly strategy call', included: false },
    ],
  },
  {
    name: 'Premium',
    price: '$500/mo',
    description: 'Businesses that want a full digital partner.',
    features: [
      { text: 'Managed hosting', included: true },
      { text: 'SSL certificate', included: true },
      { text: 'Daily backups', included: true },
      { text: 'Security monitoring', included: true },
      { text: 'Uptime monitoring', included: true },
      { text: '6 hrs/mo content updates', included: true },
      { text: 'Monthly analytics report', included: true },
      { text: 'Advanced SEO monitoring', included: true },
      { text: 'Priority support', included: true },
      { text: 'A/B testing', included: true },
      { text: 'Quarterly strategy call', included: true },
    ],
  },
];

const managedFeatures = [
  {
    icon: 'globe',
    title: 'Managed Hosting',
    description: 'Fast, reliable hosting on modern infrastructure with automatic scaling and global CDN delivery.',
  },
  {
    icon: 'lock',
    title: 'Security Monitoring',
    description: 'Real-time threat detection, malware scanning, firewall protection, and SSL certificate management.',
  },
  {
    icon: 'clock',
    title: 'Daily Backups',
    description: 'Automated daily backups with one-click restore. Your data is always safe and recoverable.',
  },
  {
    icon: 'zap',
    title: 'Performance Optimization',
    description: 'Continuous monitoring and optimization to keep your site loading fast and running smoothly.',
  },
  {
    icon: 'trending-up',
    title: 'Uptime Monitoring',
    description: '24/7 uptime monitoring with instant alerts. If something goes down, we know before you do.',
  },
  {
    icon: 'bar-chart',
    title: 'Monthly Reporting',
    description: 'Clear, actionable reports showing traffic, performance metrics, and work completed each month.',
  },
];
---

<BaseLayout
  title="Website Management & Maintenance Plans | Caspro Digital"
  description="Hassle-free website management for small businesses. Hosting, security, backups, updates, and performance monitoring starting at $150/month."
>
  <SchemaOrg schema={schemas} />
  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero (primary bg) -->
  <Hero
    variant="page"
    title="Your Website, Fully Managed"
    subtitle="Hosting. Security. Backups. Updates. Performance monitoring. All handled \u2014 so you never have to think about the technical side of your website again."
    primaryCta="See Plans & Pricing"
    primaryHref="#pricing"
    secondaryCta="Schedule a Call"
    secondaryHref="/contact/"
  />

  <!-- The Pain Point (light bg) -->
  <Section background="light">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">
        You Shouldn't Need a Tech Degree to Keep Your Website Running
      </h2>
      <div class="space-y-4 text-base md:text-lg leading-relaxed text-neutral-600">
        <p>
          Broken plugins. Security vulnerabilities. Slow load times. Expired SSL
          certificates. These are the things that quietly kill your online presence
          while you're busy running your business.
        </p>
        <p>
          Caspro Digital's management plans handle all of it. You get a team
          watching over your site every day — not just when something breaks.
        </p>
      </div>
    </div>
  </Section>

  <!-- Pricing (white bg) -->
  <Section background="white" id="pricing">
    <SectionIntro heading="Management Plans" />
    <PricingTable columns={pricingColumns} />
  </Section>

  <!-- What Managed Means (light bg) -->
  <Section background="light">
    <SectionIntro
      heading="What \u201CManaged\u201D Actually Means"
      description="Every plan includes hands-on care from our team — not just automated tools running in the background."
    />
    <Grid cols={3}>
      {managedFeatures.map((feature) => (
        <Card class="h-full">
          <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            <Icon name={feature.icon} size={20} class="text-primary-light" />
          </div>
          <h3 class="text-lg font-semibold text-neutral-900 mb-2">{feature.title}</h3>
          <p class="text-base text-neutral-600 leading-relaxed">{feature.description}</p>
        </Card>
      ))}
    </Grid>
  </Section>

  <!-- CTA Banner (primary bg) -->
  <CTABanner
    heading="Ready to Stop Worrying About Your Website?"
    description="Choose the plan that fits your business and let us handle the rest. Setup takes less than a week."
    primaryCta="Get Started Today"
  />
</BaseLayout>

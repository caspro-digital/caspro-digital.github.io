---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/blocks/Hero.astro';
import Section from '../components/layout/Section.astro';
import Grid from '../components/layout/Grid.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import CTABanner from '../components/blocks/CTABanner.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Work' },
];

const schemas = [{
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://casprodigital.com/' },
    { '@type': 'ListItem', position: 2, name: 'Work', item: 'https://casprodigital.com/portfolio/' },
  ],
}];

const projects = [
  {
    name: 'LiveFloridaNow',
    industry: 'Real Estate',
    services: ['Web Design', 'SEO'],
    description: 'Custom website for a Central Florida REALTOR\u00AE featuring property listings, neighborhood guides, testimonial integration, and a contact system. Built with Astro, optimized for local real estate search.',
    url: 'https://livefloridanow.github.io/',
  },
  {
    name: 'Nahum J Landscaping',
    industry: 'Home Services',
    services: ['Web Design', 'Local SEO'],
    description: 'Mobile-first business website for a Sanford-based landscaping company with service pages, customer testimonials, and a quote request system. Built to rank for local lawn care and landscaping searches.',
    url: 'https://nahum-landscaping.github.io/',
  },
  {
    name: 'MakArtz Films',
    industry: 'Entertainment',
    services: ['Web Design', 'Brand Identity'],
    description: 'Portfolio and agency website for an independent film production company. Custom design with a film showcase, team profiles, project submission system, and editorial journal.',
    url: 'https://makartzfilms.github.io/',
  },
];
---

<BaseLayout
  title="Our Work | Web Design Portfolio | Caspro Digital"
  description="See the websites and digital strategies Caspro Digital has built for small businesses. Real projects. Real results."
>
  <SchemaOrg schema={schemas} />
  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero (primary bg) -->
  <Hero
    variant="page"
    title="Our Work"
    subtitle="Real projects. Real businesses. Real results. Every website you see here was built with the same approach \u2014 SEO-first architecture, conversion-focused design, and ongoing management that keeps it performing."
  />

  <!-- Projects (light bg) -->
  <Section background="light">
    <Grid cols={3}>
      {projects.map((project) => (
        <Card class="h-full flex flex-col">
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="block aspect-video bg-neutral-100 rounded-lg mb-4 flex items-center justify-center border border-neutral-200 hover:border-primary-light transition-colors group"
          >
            <span class="text-primary-light font-medium text-sm group-hover:underline">View Live Site &rarr;</span>
          </a>
          <h3 class="text-lg font-semibold text-neutral-900 mb-1">{project.name}</h3>
          <p class="text-sm text-neutral-500 mb-3">{project.industry}</p>
          <p class="text-base text-neutral-600 leading-relaxed mb-4 flex-1">{project.description}</p>
          <div class="flex flex-wrap items-center gap-2 mb-3">
            {project.services.map((service) => (
              <Badge>{service}</Badge>
            ))}
          </div>
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary-light font-medium text-sm hover:text-primary transition-colors inline-flex items-center gap-1"
          >
            Visit Site &rarr;
          </a>
        </Card>
      ))}
    </Grid>
  </Section>

  <!-- Note (white bg) -->
  <Section background="white" padding="compact">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-sm text-neutral-500">
        Sites shown in active development with clients. More projects added as they launch.
      </p>
    </div>
  </Section>

  <!-- CTA Banner (primary bg) -->
  <CTABanner secondaryCta="Read Our Blog" secondaryHref="/blog/" />
</BaseLayout>

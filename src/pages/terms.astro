---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/blocks/Hero.astro';
import Section from '../components/layout/Section.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Terms of Service' },
];
---

<BaseLayout
  title="Terms of Service | Caspro Digital"
  description="Terms of service for Caspro Digital's website and services."
>
  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    variant="page"
    title="Terms of Service"
    subtitle="Last updated: April 2026"
  />

  <Section background="white">
    <div class="max-w-3xl mx-auto">
      <div class="space-y-8">
        <div>
          <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">Agreement to Terms</h2>
          <p class="text-base leading-relaxed text-neutral-700">
            By accessing or using the Caspro Digital website (casprodigital.com), you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our website.
          </p>
        </div>

        <div>
          <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">Services</h2>
          <p class="text-base leading-relaxed text-neutral-700">
            Caspro Digital LLC provides web design, search engine optimization, and website management services. Specific terms for individual service engagements are outlined in separate service agreements provided to each client before work begins.
          </p>
        </div>

        <div>
          <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">Intellectual Property</h2>
          <p class="text-base leading-relaxed text-neutral-700 mb-4">
            The content on this website, including text, graphics, logos, and images, is the property of Caspro Digital LLC and is protected by copyright and other intellectual property laws.
          </p>
          <p class="text-base leading-relaxed text-neutral-700">
            For client projects, intellectual property ownership and licensing terms are defined in the individual service agreement for each engagement.
          </p>
        </div>

        <div>
          <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">User Conduct</h2>
          <p class="text-base leading-relaxed text-neutral-700 mb-4">
            When using our website, you agree not to:
          </p>
          <ul class="list-disc pl-6 space-y-2 text-base text-neutral-700">
            <li>Use the website for any unlawful purpose</li>
            <li>Attempt to gain unauthorized access to any part of the website</li>
            <li>Interfere with or disrupt the website's functionality</li>
            <li>Submit false or misleading information through our contact forms</li>
            <li>Reproduce, distribute, or modify any content without written permission</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">Disclaimer of Warranties</h2>
          <p class="text-base leading-relaxed text-neutral-700">
            This website is provided "as is" without warranties of any kind, either express or implied. Caspro Digital does not warrant that the website will be uninterrupted, error-free, or free of viruses or other harmful components.
          </p>
        </div>

        <div>
          <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">Limitation of Liability</h2>
          <p class="text-base leading-relaxed text-neutral-700">
            To the fullest extent permitted by law, Caspro Digital LLC shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from your use of the website or our services.
          </p>
        </div>

        <div>
          <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">Governing Law</h2>
          <p class="text-base leading-relaxed text-neutral-700">
            These Terms of Service are governed by and construed in accordance with the laws of the State of Florida, without regard to its conflict of law provisions.
          </p>
        </div>

        <div>
          <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">Changes to Terms</h2>
          <p class="text-base leading-relaxed text-neutral-700">
            We reserve the right to modify these Terms of Service at any time. Changes will be effective immediately upon posting to the website. Your continued use of the website after changes are posted constitutes acceptance of the modified terms.
          </p>
        </div>

        <div>
          <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">Contact</h2>
          <p class="text-base leading-relaxed text-neutral-700">
            For questions about these Terms of Service, contact us at:<br />
            <a href="mailto:hello@casprodigital.com" class="text-primary-light hover:text-primary transition-colors">hello@casprodigital.com</a>
          </p>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>

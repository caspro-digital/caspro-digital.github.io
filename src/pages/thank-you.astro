---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/layout/Section.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
---

<BaseLayout
  title="Message Received | Caspro Digital"
  description="Thank you for reaching out. We'll be in touch shortly."
  noindex={true}
>
  <!-- Confirmation (primary bg) -->
  <Section background="primary" padding="default">
    <div class="max-w-2xl mx-auto text-center">
      <div class="w-16 h-16 rounded-full bg-success/20 flex items-center justify-center mx-auto mb-6">
        <Icon name="check" size={32} class="text-success" />
      </div>
      <h1 class="text-2xl md:text-4xl font-bold leading-tight text-white mb-4">
        Message Received!
      </h1>
      <p class="text-lg md:text-xl text-neutral-300 leading-relaxed mb-2">
        Thank you for reaching out to Caspro Digital.
      </p>
      <p class="text-base text-neutral-300 leading-relaxed">
        We'll respond within 24 hours. If your request is urgent, email us
        directly at
        <a href="mailto:hello@casprodigital.com" class="text-accent hover:text-accent-hover transition-colors underline">
          hello@casprodigital.com
        </a>.
      </p>
    </div>
  </Section>

  <!-- What to expect (light bg) -->
  <Section background="light">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">
        What Happens Next
      </h2>
      <div class="space-y-4 text-base md:text-lg leading-relaxed text-neutral-600 mb-8">
        <p>
          We'll review your message and get back to you within one business day
          with a thoughtful response — not a generic auto-reply.
        </p>
        <p>
          If it sounds like we're a good fit, we'll suggest a free 30-minute
          discovery call to learn more about your business and goals.
        </p>
      </div>
    </div>
  </Section>

  <!-- While you wait (white bg) -->
  <Section background="white">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-6">
        While You Wait
      </h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/services/" variant="secondary">Explore Our Services</Button>
        <Button href="/blog/" variant="ghost">Read Our Blog</Button>
        <Button href="/portfolio/" variant="ghost">View Our Work</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

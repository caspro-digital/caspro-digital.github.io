---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/blocks/Hero.astro';
import Section from '../components/layout/Section.astro';
import Grid from '../components/layout/Grid.astro';
import SplitLayout from '../components/layout/SplitLayout.astro';
import SectionIntro from '../components/ui/SectionIntro.astro';
import Card from '../components/ui/Card.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/ui/Button.astro';
import ProcessSteps from '../components/blocks/ProcessSteps.astro';
import PricingTable from '../components/blocks/PricingTable.astro';
import FAQ from '../components/blocks/FAQ.astro';
import CTABanner from '../components/blocks/CTABanner.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import { websiteBuildPlans } from '../data/pricing';

const processSteps = [
  {
    number: 1,
    title: 'Discovery Call',
    description:
      'We learn about your business, goals, and current digital presence. You’ll leave with a clear understanding of what’s possible and a no-obligation proposal.',
  },
  {
    number: 2,
    title: 'Strategy & Design',
    description:
      'We build your custom strategy — site architecture, keyword targets, content plan, and visual design — all before writing a single line of code. You approve everything before we build.',
  },
  {
    number: 3,
    title: 'Build & Launch',
    description:
      'We develop your site with SEO, speed, and conversions as the priority. You review, we refine, and we launch when you’re thrilled with the result.',
  },
  {
    number: 4,
    title: 'Grow & Optimize',
    description:
      'After launch, your retainer kicks in. We manage, monitor, and continuously optimize your site. Monthly reports keep you in the loop. Your site gets better every single month.',
  },
];

const faqItems = [
  {
    question: 'How much does a website cost?',
    answer:
      'Our website builds start at $2,500 for a 5–8 page business site, which includes SEO setup, hosting, and ongoing management starting at $199/month. Most small business clients invest between $2,500–$7,000 for their site plus a monthly management retainer. Every project includes a detailed proposal with transparent pricing before any work begins.',
  },
  {
    question: 'What if I already have a website?',
    answer:
      'We offer Growth & Management plans starting at $299/month for businesses that already have a site. We’ll audit your current website, take over hosting and security, improve your SEO, and send you monthly performance reports. No setup fee required — just ongoing improvement.',
  },
  {
    question: 'How long does it take to build a website?',
    answer:
      'Most business websites launch within 3–5 weeks from kickoff. Complex projects with custom functionality or e-commerce may take 6–8 weeks. We’ll give you a realistic timeline during your discovery call and keep you updated at every stage.',
  },
  {
    question: 'Do I need to sign a long-term contract?',
    answer:
      'No. Our agreements start with a 3-month minimum to allow enough time to demonstrate results, then continue month-to-month. You can cancel with 30 days notice at any time. We believe in earning your business every month, not locking you in.',
  },
  {
    question: 'Will my website show up on Google?',
    answer:
      'Every website we build is engineered for SEO from the ground up — fast load times, clean code, proper heading structure, schema markup, and optimized metadata. Our management retainers include ongoing SEO monitoring and improvements to keep your rankings climbing.',
  },
  {
    question: 'Do you work with businesses outside of Florida?',
    answer:
      'Yes. While we’re based in Central Florida, all of our services are delivered remotely. We work with small businesses and professional firms across the United States.',
  },
];

const whyUsItems = [
  {
    icon: 'search',
    title: 'SEO-First Design',
    description:
      'Every website we build is engineered to rank on Google from day one. SEO isn’t an add-on — it’s the foundation.',
  },
  {
    icon: 'file-text',
    title: 'Transparent Pricing',
    description:
      'No hidden fees. No surprise invoices. You know exactly what you’re paying for before we write a single line of code.',
  },
  {
    icon: 'shield',
    title: 'Fully Managed Service',
    description:
      'We handle everything — domain, hosting, security, updates, and ongoing optimization. You never have to think about the technical side.',
  },
  {
    icon: 'bar-chart',
    title: 'Real Results, Measured Monthly',
    description:
      'Every retainer client gets monthly performance reports showing exactly how their site is performing, what’s improving, and what we’re working on next.',
  },
];

const homepageSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Caspro Digital',
    url: 'https://casprodigital.com',
    description: 'Web design, SEO, and website management for small businesses and professional firms.',
    email: 'hello@casprodigital.com',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Sanford',
      addressRegion: 'FL',
      addressCountry: 'US',
    },
    areaServed: { '@type': 'Country', name: 'United States' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'Caspro Digital',
    url: 'https://casprodigital.com',
    email: 'hello@casprodigital.com',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Sanford',
      addressRegion: 'FL',
      addressCountry: 'US',
    },
    areaServed: { '@type': 'Country', name: 'United States' },
    priceRange: '$$',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout
  title="Caspro Digital | Web Design & SEO for Small Businesses"
  description="Caspro Digital builds and manages high-performance websites for small businesses. SEO-first design, transparent pricing, and fully managed service. Based in Central Florida, serving clients nationwide."
>
  <SchemaOrg schema={homepageSchemas} />

  <!-- Hero (primary bg) -->
  <Hero
    variant="home"
    eyebrow="Web Design &bull; SEO &bull; Managed Websites"
    title="Websites That Get Your Business Found on Google"
    subtitle="We build and manage high-performance websites for small businesses — with SEO, hosting, security, and monthly optimization included. You run your business. We make your website work."
    primaryCta="Schedule a Free Consultation"
    primaryHref="/contact/"
    secondaryCta="See Our Work"
    secondaryHref="/portfolio/"
    proofItems={[
      'No contracts longer than 3 months',
      'Transparent pricing',
      'SEO-first approach',
    ]}
  />

  <!-- Two-Path Section (light bg) -->
  <Section background="light">
    <Grid cols={2}>
      <Card class="h-full flex flex-col">
        <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
          <Icon name="monitor" size={24} class="text-primary-light" />
        </div>
        <h2 class="text-lg md:text-xl font-semibold text-neutral-900 mb-2">Need a New Website?</h2>
        <p class="text-base text-neutral-600 leading-relaxed mb-4 flex-1">
          We design and build modern, SEO-optimized websites that look professional and generate leads. Custom-built for your business, ready to rank on Google from day one.
        </p>
        <a
          href="/services/"
          class="text-primary-light font-medium text-sm hover:text-primary transition-colors inline-flex items-center gap-1"
        >
          Learn about website builds
          <Icon name="arrow-right" size={16} />
        </a>
      </Card>
      <Card class="h-full flex flex-col">
        <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
          <Icon name="trending-up" size={24} class="text-primary-light" />
        </div>
        <h2 class="text-lg md:text-xl font-semibold text-neutral-900 mb-2">Already Have a Website?</h2>
        <p class="text-base text-neutral-600 leading-relaxed mb-4 flex-1">
          We improve your SEO, speed, and security — then manage everything monthly. Your website gets better every month without you thinking about it.
        </p>
        <a
          href="/services/#growth"
          class="text-primary-light font-medium text-sm hover:text-primary transition-colors inline-flex items-center gap-1"
        >
          Learn about growth & management
          <Icon name="arrow-right" size={16} />
        </a>
      </Card>
    </Grid>
  </Section>

  <!-- Pricing Preview (white bg) -->
  <Section background="white">
    <SectionIntro
      heading="Simple, Transparent Pricing"
      description="Every project includes SEO, hosting, security, and ongoing management. No hidden fees."
    />
    <PricingTable columns={websiteBuildPlans} />
    <div class="max-w-2xl mx-auto text-center mt-8 md:mt-12">
      <p class="text-base md:text-lg leading-relaxed text-neutral-600 mb-6">
        Already have a website? Our Growth & Management plans start at $299/mo with no setup fee. We'll audit your site, take over hosting and security, and start improving your SEO immediately.
      </p>
      <Button href="/services/#growth" variant="ghost">
        Learn More
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7l7 7-7 7" />
        </svg>
      </Button>
    </div>
  </Section>

  <!-- Why Caspro Digital (light bg) -->
  <Section background="light">
    <SplitLayout split="60-40" alignY="top">
      <div>
        <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">
          Why Businesses Choose Caspro Digital
        </h2>
        <p class="text-base md:text-lg leading-relaxed text-neutral-600">
          We're not a faceless agency. We're a dedicated digital partner that treats
          your business like our own.
        </p>
      </div>
      <div class="space-y-6">
        {whyUsItems.map((item) => (
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0 mt-1">
              <Icon name={item.icon} size={20} class="text-primary-light" />
            </div>
            <div>
              <h3 class="text-lg font-semibold text-neutral-900 mb-1">{item.title}</h3>
              <p class="text-base text-neutral-600 leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </SplitLayout>
  </Section>

  <!-- The Process (white bg) -->
  <Section background="white">
    <SectionIntro
      heading="How It Works"
      description="From first conversation to launch and beyond — here's what working with Caspro Digital looks like."
    />
    <ProcessSteps steps={processSteps} />
  </Section>

  <!-- Social Proof (light bg) -->
  <Section background="light" padding="compact">
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 text-neutral-600">
      <div class="flex items-center gap-2">
        <Icon name="globe" size={20} class="text-primary-light" />
        <span class="text-base font-medium">3 Websites Launched</span>
      </div>
      <div class="flex items-center gap-2">
        <Icon name="map-pin" size={20} class="text-primary-light" />
        <span class="text-base font-medium">Central Florida Based</span>
      </div>
      <div class="flex items-center gap-2">
        <Icon name="star" size={20} class="text-primary-light" />
        <span class="text-base font-medium">100% Client Satisfaction</span>
      </div>
    </div>
  </Section>

  <!-- FAQ (white bg) -->
  <Section background="white">
    <SectionIntro heading="Frequently Asked Questions" />
    <FAQ items={faqItems} />
  </Section>

  <!-- CTA Banner (primary bg) -->
  <CTABanner />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/blocks/Hero.astro';
import Section from '../components/layout/Section.astro';
import Grid from '../components/layout/Grid.astro';
import SplitLayout from '../components/layout/SplitLayout.astro';
import SectionIntro from '../components/ui/SectionIntro.astro';
import Card from '../components/ui/Card.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/ui/Button.astro';
import ProcessSteps from '../components/blocks/ProcessSteps.astro';
import FAQ from '../components/blocks/FAQ.astro';
import CTABanner from '../components/blocks/CTABanner.astro';
import { services } from '../data/services';

const processSteps = [
  {
    number: 1,
    title: 'Discovery Call',
    description:
      'We learn about your business, goals, and current digital presence. You\u2019ll leave with a clear understanding of what\u2019s possible and a no-obligation proposal.',
  },
  {
    number: 2,
    title: 'Strategy & Design',
    description:
      'We build your custom strategy \u2014 site architecture, keyword targets, content plan, and visual design \u2014 all before writing a single line of code. You approve everything before we build.',
  },
  {
    number: 3,
    title: 'Build & Launch',
    description:
      'We develop your site with SEO, speed, and conversions as the priority. You review, we refine, and we launch when you\u2019re thrilled with the result.',
  },
  {
    number: 4,
    title: 'Grow & Optimize',
    description:
      'After launch, your retainer kicks in. We manage, monitor, and continuously optimize your site. Monthly reports keep you in the loop. Your site gets better every single month.',
  },
];

const faqItems = [
  {
    question: 'How much does a website cost?',
    answer:
      'Our website projects start at $1,500 for a 5\u20137 page business site and range up to $10,000+ for complex custom builds with e-commerce. Every project includes a detailed proposal with transparent pricing before any work begins. Most of our small business clients invest between $2,000\u2013$5,000 for their website plus a monthly retainer starting at $150/month for ongoing management.',
  },
  {
    question: 'How long does it take to build a website?',
    answer:
      'Most business websites launch within 3\u20135 weeks from kickoff. Complex projects with custom functionality or e-commerce may take 6\u20138 weeks. We\u2019ll give you a realistic timeline during your discovery call and keep you updated at every stage.',
  },
  {
    question: 'Do I need to sign a long-term contract?',
    answer:
      'No. Our retainer agreements start with a 3-month minimum to allow enough time to demonstrate results, then continue month-to-month. You can cancel with 30 days notice at any time. We believe in earning your business every month, not locking you in.',
  },
  {
    question: 'Will my website show up on Google?',
    answer:
      'Every website we build is engineered for SEO from the ground up \u2014 fast load times, clean code, proper heading structure, schema markup, and optimized metadata. For clients who add our SEO retainer, we actively work on improving your rankings through content strategy, link building, and ongoing optimization.',
  },
  {
    question: 'I already have a website. Can you improve it?',
    answer:
      'Absolutely. We offer website audits that identify exactly what\u2019s holding your site back. From there, we can recommend a redesign, an optimization plan, or targeted improvements depending on what will move the needle most for your business.',
  },
  {
    question: 'Do you work with businesses outside of Florida?',
    answer:
      'Yes. While we\u2019re based in Central Florida, all of our services are delivered remotely. We work with small businesses and professional firms across the United States.',
  },
];

const whyUsItems = [
  {
    icon: 'search',
    title: 'SEO-First Design',
    description:
      'Every website we build is engineered to rank on Google from day one. SEO isn\u2019t an add-on \u2014 it\u2019s the foundation.',
  },
  {
    icon: 'file-text',
    title: 'Transparent Pricing',
    description:
      'No hidden fees. No surprise invoices. You know exactly what you\u2019re paying for before we write a single line of code.',
  },
  {
    icon: 'shield',
    title: 'Fully Managed Service',
    description:
      'We handle everything \u2014 domain, hosting, security, updates, and ongoing optimization. You never have to think about the technical side.',
  },
  {
    icon: 'bar-chart',
    title: 'Real Results, Measured Monthly',
    description:
      'Every retainer client gets monthly performance reports showing exactly how their site is performing, what\u2019s improving, and what we\u2019re working on next.',
  },
];
---

<BaseLayout
  title="Caspro Digital | Web Design, SEO & Tech Consulting"
  description="Caspro Digital builds high-performance websites and SEO strategies for small businesses and professional firms. Based in Central Florida, serving clients nationwide."
>
  <!-- Section 1: Hero (primary bg) -->
  <Hero
    variant="home"
    eyebrow="Web Design &bull; SEO &bull; Tech Consulting"
    title="Websites That Work as Hard as You Do"
    subtitle="We design, build, and manage high-performance websites for small businesses and professional firms — with SEO baked into every pixel. You focus on running your business. We handle your entire digital presence."
    primaryCta="Schedule a Free Consultation"
    primaryHref="/contact/"
    secondaryCta="See Our Work"
    secondaryHref="/portfolio/"
    proofItems={[
      'No contracts longer than 3 months',
      'Transparent pricing',
      'SEO-first approach',
    ]}
  />

  <!-- Section 2: The Problem (light bg) -->
  <Section background="light">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">
        Your Website Should Be Your Best Salesperson
      </h2>
      <div class="space-y-4 text-base md:text-lg leading-relaxed text-neutral-600">
        <p>
          Most small business websites are digital brochures that sit there doing nothing.
          No traffic. No leads. No strategy behind them.
        </p>
        <p>
          Meanwhile, your competitors are showing up on Google, collecting leads while
          they sleep, and growing their business online.
        </p>
        <p>
          The difference isn't luck. It's having a website built with intention — designed
          to rank, engineered to convert, and maintained to perform month after month.
        </p>
      </div>
    </div>
  </Section>

  <!-- Section 3: Services Overview (white bg) -->
  <Section background="white">
    <SectionIntro
      heading="What We Do"
      description="Everything your business needs to succeed online — under one roof."
    />
    <Grid cols={4}>
      {services.map((service) => (
        <Card class="h-full flex flex-col">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            <Icon name={service.icon} size={24} class="text-primary-light" />
          </div>
          <h3 class="text-lg font-semibold text-neutral-900 mb-2">{service.name}</h3>
          <p class="text-base text-neutral-600 leading-relaxed mb-4 flex-1">
            {service.description}
          </p>
          <a
            href={service.href}
            class="text-primary-light font-medium text-sm hover:text-primary transition-colors inline-flex items-center gap-1"
          >
            Learn more
            <Icon name="arrow-right" size={16} />
          </a>
        </Card>
      ))}
    </Grid>
  </Section>

  <!-- Section 4: Why Caspro Digital (light bg) -->
  <Section background="light">
    <SplitLayout split="60-40" alignY="top">
      <div>
        <h2 class="text-xl md:text-3xl font-semibold leading-snug text-neutral-900 mb-4">
          Why Businesses Choose Caspro Digital
        </h2>
        <p class="text-base md:text-lg leading-relaxed text-neutral-600">
          We're not a faceless agency. We're a dedicated digital partner that treats
          your business like our own.
        </p>
      </div>
      <div class="space-y-6">
        {whyUsItems.map((item) => (
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0 mt-1">
              <Icon name={item.icon} size={20} class="text-primary-light" />
            </div>
            <div>
              <h3 class="text-lg font-semibold text-neutral-900 mb-1">{item.title}</h3>
              <p class="text-base text-neutral-600 leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </SplitLayout>
  </Section>

  <!-- Section 5: The Process (white bg) -->
  <Section background="white">
    <SectionIntro
      heading="How It Works"
      description="From first conversation to launch and beyond — here's what working with Caspro Digital looks like."
    />
    <ProcessSteps steps={processSteps} />
  </Section>

  <!-- Section 6: Social Proof (light bg) -->
  <Section background="light" padding="compact">
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 text-neutral-600">
      <div class="flex items-center gap-2">
        <Icon name="globe" size={20} class="text-primary-light" />
        <span class="text-base font-medium">3 Websites Launched</span>
      </div>
      <div class="flex items-center gap-2">
        <Icon name="map-pin" size={20} class="text-primary-light" />
        <span class="text-base font-medium">Central Florida Based</span>
      </div>
      <div class="flex items-center gap-2">
        <Icon name="star" size={20} class="text-primary-light" />
        <span class="text-base font-medium">100% Client Satisfaction</span>
      </div>
    </div>
  </Section>

  <!-- Section 7: FAQ (white bg) -->
  <Section background="white">
    <SectionIntro heading="Frequently Asked Questions" />
    <FAQ items={faqItems} />
  </Section>

  <!-- Section 8: CTA Banner (primary bg) -->
  <CTABanner />
</BaseLayout>

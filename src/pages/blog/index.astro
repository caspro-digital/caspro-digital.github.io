---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/blocks/Hero.astro';
import Section from '../../components/layout/Section.astro';
import Grid from '../../components/layout/Grid.astro';
import Card from '../../components/ui/Card.astro';
import Badge from '../../components/ui/Badge.astro';
import CTABanner from '../../components/blocks/CTABanner.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import SchemaOrg from '../../components/seo/SchemaOrg.astro';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog' },
];

const schemas = [{
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://casprodigital.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://casprodigital.com/blog/' },
  ],
}];

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog | Web Design, SEO & Digital Strategy Insights | Caspro Digital"
  description="Practical insights on web design, SEO, and digital strategy for small businesses. No jargon, no fluff — just actionable advice from Caspro Digital."
>
  <SchemaOrg schema={schemas} />
  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero (primary bg) -->
  <Hero
    variant="page"
    title="Insights & Resources"
    subtitle="Practical insights on web design, SEO, and digital strategy for small businesses. No jargon, no fluff — just actionable advice."
  />

  <!-- Posts (light bg) -->
  <Section background="light">
    {posts.length > 0 ? (
      <Grid cols={3}>
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="block h-full">
            <Card class="h-full flex flex-col">
              {post.data.image && (
                <div class="aspect-video bg-neutral-200 rounded-lg mb-4 overflow-hidden">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}
              {!post.data.image && (
                <div class="aspect-video bg-primary/5 rounded-lg mb-4 flex items-center justify-center">
                  <svg class="w-8 h-8 text-primary-light/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                  </svg>
                </div>
              )}
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags?.slice(0, 2).map((tag) => (
                  <Badge>{tag}</Badge>
                ))}
              </div>
              <h2 class="text-lg font-semibold text-neutral-900 mb-2 group-hover:text-primary-light transition-colors">
                {post.data.title}
              </h2>
              <p class="text-base text-neutral-600 leading-relaxed mb-4 flex-1">
                {post.data.description}
              </p>
              <p class="text-sm text-neutral-400 mt-auto">
                {formatDate(post.data.date)} &middot; {post.data.author}
              </p>
            </Card>
          </a>
        ))}
      </Grid>
    ) : (
      <div class="max-w-2xl mx-auto text-center py-12">
        <p class="text-base md:text-lg leading-relaxed text-neutral-600">
          New articles coming soon. Check back for practical insights on web design, SEO, and growing your business online.
        </p>
      </div>
    )}
  </Section>

  <!-- CTA Banner (primary bg) -->
  <CTABanner
    heading="Want Insights Delivered to Your Inbox?"
    description="We publish practical, jargon-free articles on web design, SEO, and digital strategy for small businesses."
    primaryCta="Get in Touch"
    secondaryCta=""
  />
</BaseLayout>

---
interface Feature {
  text: string;
}

interface PricingColumn {
  name: string;
  price: string;
  period?: string;
  description: string;
  features: Feature[];
  featured?: boolean;
  ctaText?: string;
  ctaHref?: string;
}

interface Props {
  columns: PricingColumn[];
  class?: string;
}

import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';

const { columns, class: className = '' } = Astro.props;
---

<div class:list={['grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 items-stretch', className]}>
  {columns.map((col) => (
    <div class:list={[
      'pricing-table__column',
      col.featured && 'pricing-table__column--featured'
    ]}>
      {col.featured && (
        <div class="pricing-table__badge">
          <Badge variant="accent">Most Popular</Badge>
        </div>
      )}
      <h3 class="pricing-table__name">{col.name}</h3>
      <div class="pricing-table__price">{col.price}</div>
      {col.period && <p class="pricing-table__period">{col.period}</p>}
      <p class="pricing-table__description">{col.description}</p>
      <ul class="pricing-table__features">
        {col.features.map((feature) => (
          <li class="pricing-table__feature">
            <svg class="pricing-table__check" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>{feature.text}</span>
          </li>
        ))}
      </ul>
      <Button
        href={col.ctaHref || '/contact/'}
        variant={col.featured ? 'primary' : 'secondary'}
        class="w-full text-center mt-auto"
      >
        {col.ctaText || 'Get Started'}
      </Button>
    </div>
  ))}
</div>

<style>
  @reference "../../styles/global.css";
  .pricing-table__column {
    @apply bg-white rounded-xl border border-neutral-200 p-6 md:p-8 relative flex flex-col;
  }
  .pricing-table__column--featured {
    @apply border-primary-light border-2 shadow-lg;
  }
  .pricing-table__badge {
    @apply absolute -top-3 left-1/2 -translate-x-1/2;
  }
  .pricing-table__name {
    @apply text-lg font-semibold text-neutral-900 mb-1;
  }
  .pricing-table__price {
    @apply text-3xl font-bold text-neutral-900 mb-1;
  }
  .pricing-table__period {
    @apply text-sm text-neutral-500;
  }
  .pricing-table__description {
    @apply text-sm text-neutral-500 mb-6;
  }
  .pricing-table__features {
    @apply space-y-3 mb-8;
  }
  .pricing-table__feature {
    @apply flex items-start gap-2 text-sm text-neutral-700;
  }
  .pricing-table__check {
    @apply w-5 h-5 text-success shrink-0 mt-0.5;
  }
</style>

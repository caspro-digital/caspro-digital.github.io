---
interface Props {
  variant?: 'home' | 'page';
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: string;
  primaryHref?: string;
  secondaryCta?: string;
  secondaryHref?: string;
  proofItems?: string[];
}

import Button from '../ui/Button.astro';

const {
  variant = 'page',
  eyebrow,
  title,
  subtitle,
  primaryCta,
  primaryHref = '/contact/',
  secondaryCta,
  secondaryHref = '/portfolio/',
  proofItems,
} = Astro.props;

const isHome = variant === 'home';
---

<section class:list={[
  'relative overflow-hidden bg-primary text-white',
  isHome ? 'min-h-[80vh] flex items-center' : ''
]}>
  <div class:list={[
    'mx-auto max-w-7xl px-6 md:px-8',
    isHome ? 'py-20 md:py-32' : 'py-12 md:py-20',
  ]}>
    <div class="max-w-3xl">
      {eyebrow && (
        <p class="hero__eyebrow">{eyebrow}</p>
      )}
      <h1 class:list={[
        'text-white mb-6',
        isHome
          ? 'text-3xl md:text-5xl font-bold leading-tight'
          : 'text-2xl md:text-4xl font-bold leading-tight'
      ]}>
        {title}
      </h1>
      {subtitle && (
        <p class="hero__subtitle">{subtitle}</p>
      )}
      {(primaryCta || secondaryCta) && (
        <div class="hero__actions">
          {primaryCta && (
            <Button href={primaryHref} variant="primary" size={isHome ? 'lg' : 'md'}>
              {primaryCta}
            </Button>
          )}
          {secondaryCta && (
            <Button href={secondaryHref} variant="white" size={isHome ? 'lg' : 'md'}>
              {secondaryCta}
            </Button>
          )}
        </div>
      )}
      {proofItems && proofItems.length > 0 && (
        <div class="hero__proof">
          {proofItems.map((item) => (
            <span class="hero__proof-item">
              <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  @reference "../../styles/global.css";
  .hero__eyebrow {
    @apply text-sm font-medium uppercase tracking-wide text-accent mb-4;
  }
  .hero__subtitle {
    @apply text-lg md:text-xl text-neutral-300 leading-relaxed max-w-2xl mb-8;
  }
  .hero__actions {
    @apply flex flex-col sm:flex-row gap-4 mb-8;
  }
  .hero__proof {
    @apply flex flex-wrap gap-x-6 gap-y-2 text-sm text-neutral-300;
  }
  .hero__proof-item {
    @apply flex items-center gap-2;
  }
</style>

---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;
---

<nav aria-label="Breadcrumb" class:list={['py-4', className]}>
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <ol class="flex flex-wrap items-center gap-1 text-sm text-neutral-400">
      {items.map((item, index) => (
        <li class="flex items-center gap-1">
          {index > 0 && (
            <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          )}
          {item.href ? (
            <a href={item.href} class="text-neutral-500 hover:text-primary-light transition-colors">
              {item.label}
            </a>
          ) : (
            <span class="text-neutral-900 font-medium">{item.label}</span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>

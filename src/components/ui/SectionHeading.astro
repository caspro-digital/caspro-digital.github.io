---
interface Props {
  as?: 'h1' | 'h2' | 'h3';
  size?: 'display' | 'heading-1' | 'heading-2' | 'heading-3';
  class?: string;
}

const { as: Tag = 'h2', size = 'heading-2', class: className = '' } = Astro.props;

const sizeClasses: Record<string, string> = {
  'display': 'text-3xl md:text-5xl font-bold leading-tight',
  'heading-1': 'text-2xl md:text-4xl font-bold leading-tight',
  'heading-2': 'text-xl md:text-3xl font-semibold leading-snug',
  'heading-3': 'text-lg md:text-xl font-semibold leading-snug',
};
---

<Tag class:list={[sizeClasses[size], 'text-neutral-900', className]}>
  <slot />
</Tag>

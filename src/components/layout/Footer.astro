---
import { footerServices, footerCompany, footerConnect } from '../../data/navigation';
import Button from '../ui/Button.astro';
---

<footer class="bg-primary-dark text-white">
  <div class="mx-auto max-w-7xl px-6 md:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 md:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="text-white font-bold text-xl inline-block mb-4">Caspro Digital</a>
        <p class="text-neutral-300 text-base leading-relaxed mb-6 max-w-sm">
          We build and manage websites that get small businesses found on Google.
        </p>
        <Button href="/contact/" variant="primary" size="sm">Get Started</Button>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-neutral-400 mb-4">Services</h3>
        <ul class="space-y-3">
          {footerServices.map((link) => (
            <li>
              <a href={link.href} class="text-neutral-300 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-neutral-400 mb-4">Company</h3>
        <ul class="space-y-3">
          {footerCompany.map((link) => (
            <li>
              <a href={link.href} class="text-neutral-300 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-neutral-400 mb-4">Connect</h3>
        <ul class="space-y-3">
          {footerConnect.map((link) => (
            <li>
              <a href={link.href} class="text-neutral-300 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Tagline -->
    <p class="text-neutral-400 text-sm mt-8 pt-8 border-t border-white/10 text-center">
      Serving Central Florida & Nationwide
    </p>

    <!-- Bottom Bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-6 text-neutral-400 text-sm">
      <p>&copy; {new Date().getFullYear()} Caspro Digital LLC. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms/" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
